# Tracked example only. Put real production-like mail smoke values in .env.production.local (gitignored).
# Production runtime profile
APP_ENV=production
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://field-agreement-jihoon.fly.dev
TRUSTED_ORIGINS=

# External Postgres target
STORAGE_ENGINE=POSTGRES
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# If direct connectivity is not suitable, use the Supabase session pooler connection string instead.
POSTGRES_SSL_MODE=require
POSTGRES_SSL_REQUIRE=true
POSTGRES_SSL_CA_PATH=
POSTGRES_APPLICATION_NAME=damit-production-app
POSTGRES_POOL_MAX=10

# Session / auth
SESSION_COOKIE_NAME=faa_session
REFRESH_COOKIE_NAME=faa_refresh
CSRF_COOKIE_NAME=faa_csrf
SESSION_COOKIE_SAMESITE=Strict
CSRF_COOKIE_SAMESITE=Strict
SESSION_MAX_AGE_SECONDS=28800
REFRESH_SESSION_MAX_AGE_SECONDS=2592000
SESSION_IDLE_TIMEOUT_SECONDS=43200
AUTH_CHALLENGE_TTL_MINUTES=15
AUTH_ENFORCE_TRUSTED_ORIGIN=true
AUTH_DEBUG_LINKS=false
OWNER_TOKEN=replace-with-production-owner-token
OWNER_ID=owner_prod

# Mail
MAIL_PROVIDER=RESEND
MAIL_FROM=login@damit.local
CUSTOMER_NOTIFICATION_PRIMARY=KAKAO_ALIMTALK
CUSTOMER_NOTIFICATION_FALLBACK=SMS
KAKAO_BIZMESSAGE_PROVIDER=SOLAPI
SMS_PROVIDER=SOLAPI
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=
SOLAPI_KAKAO_PFID=
SOLAPI_KAKAO_TEMPLATE_ID=
RESEND_API_KEY=replace-with-production-resend-key
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Abuse hardening
INVITATION_CREATE_RATE_LIMIT_COUNT=8
INVITATION_CREATE_RATE_LIMIT_WINDOW_SECONDS=600
INVITATION_REISSUE_RATE_LIMIT_COUNT=12
INVITATION_REISSUE_RATE_LIMIT_WINDOW_SECONDS=600

# Storage / uploads
OBJECT_STORAGE_PROVIDER=LOCAL_VOLUME
OBJECT_STORAGE_BUCKET=
DATA_DIR=/data
DB_FILE_PATH=/data/app.sqlite
UPLOAD_DIR=/data/uploads
BACKUP_DIR=/data/backups
