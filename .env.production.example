# Production runtime profile
APP_ENV=production
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://field-agreement-jihoon.fly.dev

# External Postgres target
STORAGE_ENGINE=POSTGRES
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# If direct connectivity is not suitable, use the Supabase session pooler connection string instead.
POSTGRES_SSL_MODE=require
POSTGRES_SSL_REQUIRE=true
POSTGRES_SSL_CA_PATH=
POSTGRES_APPLICATION_NAME=damit-production-app
POSTGRES_POOL_MAX=10

# Session / auth
SESSION_COOKIE_NAME=faa_session
REFRESH_COOKIE_NAME=faa_refresh
CSRF_COOKIE_NAME=faa_csrf
OWNER_TOKEN=replace-with-production-owner-token
OWNER_ID=owner_prod

# Mail
MAIL_PROVIDER=RESEND
MAIL_FROM=alerts@field-agreement.local
RESEND_API_KEY=replace-with-production-resend-key

# Storage / uploads
OBJECT_STORAGE_PROVIDER=LOCAL_VOLUME
OBJECT_STORAGE_BUCKET=
DATA_DIR=/data
DB_FILE_PATH=/data/app.sqlite
UPLOAD_DIR=/data/uploads
BACKUP_DIR=/data/backups