APP_ENV_FILE=.env.preview-postgres
APP_CONTAINER_NAME=damit-homelab-preview-postgres
APP_HOST_BIND=127.0.0.1
APP_PORT=3211
DATA_BIND_DIR=/home/jihoon/damit/data-preview-postgres

APP_BASE_URL=https://preview.damit.kr
TRUSTED_ORIGINS=https://preview.damit.kr

STORAGE_ENGINE=POSTGRES
DATABASE_URL=postgresql://replace-me
POSTGRES_SSL_MODE=require
POSTGRES_APPLICATION_NAME=damit-preview-postgres
POSTGRES_POOL_MAX=10

OBJECT_STORAGE_PROVIDER=LOCAL_VOLUME
MAIL_PROVIDER=RESEND
MAIL_FROM=login@updates.damit.kr
OWNER_TOKEN=replace-with-a-long-random-token
OWNER_ID=owner_demo
NODE_ENV=production
AUTH_ENFORCE_TRUSTED_ORIGIN=true
AUTH_DEBUG_LINKS=false
TRUST_PROXY_HEADERS=true
SENTRY_DSN=
SENTRY_ENVIRONMENT=preview-postgres
SENTRY_RELEASE=
