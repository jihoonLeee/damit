APP_HOST_BIND=127.0.0.1
APP_PORT=3210
DATA_BIND_DIR=/srv/damit/data
APP_BASE_URL=http://localhost:3210
TRUSTED_ORIGINS=http://localhost:3210
STORAGE_ENGINE=SQLITE
OBJECT_STORAGE_PROVIDER=LOCAL_VOLUME
MAIL_PROVIDER=FILE
MAIL_FROM=login@damit.local
OWNER_TOKEN=replace-with-a-long-random-token
OWNER_ID=owner_demo
NODE_ENV=production
AUTH_ENFORCE_TRUSTED_ORIGIN=true
AUTH_DEBUG_LINKS=true

# Optional real-mail values belong in a local ignored env file, not here.
RESEND_API_KEY=
MAIL_SMOKE_TEST_EMAIL=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Optional authenticated invitation abuse tuning
INVITATION_CREATE_RATE_LIMIT_COUNT=8
INVITATION_CREATE_RATE_LIMIT_WINDOW_SECONDS=600
INVITATION_REISSUE_RATE_LIMIT_COUNT=12
INVITATION_REISSUE_RATE_LIMIT_WINDOW_SECONDS=600
