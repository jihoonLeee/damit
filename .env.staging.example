# Staging runtime profile
APP_ENV=staging
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://field-agreement-jihoon-staging.fly.dev

# Bootstrap staging target
STORAGE_ENGINE=SQLITE
DATABASE_URL=
# Supabase on Fly.io: try the direct connection string first, then fall back to the session pooler if needed.
# Direct example: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Session pooler example: postgres://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
POSTGRES_SSL_MODE=require
POSTGRES_SSL_REQUIRE=true
POSTGRES_SSL_CA_PATH=
POSTGRES_APPLICATION_NAME=damit-staging-app
POSTGRES_POOL_MAX=10

# Session / auth
SESSION_COOKIE_NAME=faa_session
REFRESH_COOKIE_NAME=faa_refresh
CSRF_COOKIE_NAME=faa_csrf
OWNER_TOKEN=replace-with-staging-owner-token
OWNER_ID=owner_staging

# Mail
MAIL_PROVIDER=FILE
MAIL_FROM=staging@field-agreement.local
RESEND_API_KEY=

# Storage / uploads
OBJECT_STORAGE_PROVIDER=LOCAL_VOLUME
OBJECT_STORAGE_BUCKET=
DATA_DIR=/data
DB_FILE_PATH=/data/app.sqlite
UPLOAD_DIR=/data/uploads
BACKUP_DIR=/data/backups